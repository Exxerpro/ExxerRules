<Project Sdk="Microsoft.NET.Sdk">
  <!-- ============================================================================ -->
  <!-- CORE PROPERTIES -->
  <!-- ============================================================================ -->
  <PropertyGroup>
    <!-- Target Framework -->
    <TargetFramework>net10.0</TargetFramework>
    <!-- Language Features -->
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <!-- Assembly Information -->
    <RootNamespace>IndTrace.Application</RootNamespace>
    <AssemblyName>IndTrace.Application</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Application: allow only NU1902 suppression -->
    <!-- Fobiden to add global scoped NoWarn  violator to this rule will be prosecuted -->
    <!-- Versioning -->
    <AssemblyVersion>2025.5.30.51</AssemblyVersion>
    <FileVersion>2025.5.30.51</FileVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - TESTING -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Testing">
    <PackageReference Include="NSubstitute" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - DATA & FILE PROCESSING -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Data Processing">
    <PackageReference Include="Microsoft.AspNetCore.Http" />
    <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" />
    <PackageReference Include="CsvHelper" />
    <PackageReference Include="QRCoder" />
    <PackageReference Include="ZXing.Net" />
    <PackageReference Include="System.Drawing.Common" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - DATABASE -->
  <!-- ============================================================================ -->
  <!-- [ARCH] Minimal EF Core reference for extension methods only - TODO: Remove remaining direct EF usage -->
  <ItemGroup Label="Database - MINIMAL">
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - CACHING & PERFORMANCE -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Caching Performance">
    <PackageReference Include="Microsoft.Extensions.ObjectPool" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - HEALTH CHECKS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="HealthChecks">
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - VALIDATION -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Validation">
    <PackageReference Include="FluentValidation" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PROJECT REFERENCES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Core References">
    <ProjectReference Include="..\Domain\IndTrace.Domain.csproj" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- GENERATOR REFERENCES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Generator References">
    <ProjectReference Include="..\..\Generators\IndTrace.Generators\IndTrace.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- SOLUTION FOLDERS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Solution Folders">
    <Folder Include="Extensions\" />
    <Folder Include="Generic\Commands\Create\" />
    <Folder Include="NewFolder\" />
  </ItemGroup>


  <!-- ============================================================================ -->
  <!-- RESULT AND RESULT ANALYZERS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Result and Result Analyzers">

	  <PackageReference Include="IndQuestResults" />
	  <PackageReference Include="IndFusion.Fixer" />
	  <PackageReference Include="IndFusion.Analyzer">
		  <PrivateAssets>all</PrivateAssets>
		  <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
	  </PackageReference>
	  <!--<PackageReference Include="IndQuestResults.Analyzers">
		  <PrivateAssets>all</PrivateAssets>
		  <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
	  </PackageReference>-->
  </ItemGroup>

</Project>
