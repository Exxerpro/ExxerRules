{
  "ConnectionStrings": {
    "IndTraceDbContext": "Server=localhost;Database=IndTraceDataQA45;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbContext62": "Server=DESKTOP-FB2ES22;Database=IndTraceDataQA62;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbContext45": "Server=DESKTOP-FB2ES22;Database=IndTraceDataQA45;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbIdentity": "Server=localhost;Database=IndTraceIdentity;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;"
  },
  "DataManSettings": {
    "IpAddress": "localhost",
    "UserName": "admin",
    "Password": "admin"
  },
  "HubMonitorOptions": {
    "Url": "https://localhost:5201/eventmonitor",
    "AcceptAnyServerCertificate": true,
    "RetryTime": 5000
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Seq", "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "LevelSwitches": { "$controlSwitch": "Information" },
    "Override": {
      "Microsoft": "Information",
      "Microsoft.AspNetCore.SignalR": "Information"
      "Microsoft.AspNetCore.SignalR.Client.HubConnection": "Information",
      "Microsoft.EntityFrameworkCore": "Error"
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "controlLevelSwitch": "$controlSwitch"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level}] ({Caller}){NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "D:\\Logs\\IndTrace\\Simulation\\Log-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": "100000000",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithExceptionDetails", "WithDemystifier" ],
    "Properties": {
      "Application": "IndTrace.Communications"
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Contains(@Message, 'Failed to find handler for') or Contains(@Message, 'Failed to bind arguments received in invocation') or Contains(@Message, 'System.IO.InvalidDataException: Invocation provides 2 argument(s) but target expects 0')"
        }
      }
    ]
  },
  "DryRunOptions": {
    "IsDryRun": "true",
    "NumberOfRun": "1",
    "CycleDelayMs": "1000",
    "CommandDelayMs": "1000",
    "StationChangeBarCodeTimeMs": "1400",
    "MaxNumberOfRetry": 2,
    "WaitTimeForResponse": "3600",
    "DelayTimeBetweenRetries": "1600",
    "CycleTimeAverageTimeMs": "5000"
  }
}
