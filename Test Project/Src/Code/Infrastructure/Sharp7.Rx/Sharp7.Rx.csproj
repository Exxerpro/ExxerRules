<Project Sdk="Microsoft.NET.Sdk">
  <!-- ============================================================================ -->
  <!-- CORE PROPERTIES -->
  <!-- ============================================================================ -->
  <PropertyGroup>
    <!-- Target Framework -->
    <TargetFramework>net10.0</TargetFramework>
    <!-- Language Features -->
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Code Analysis -->
    <AnalysisLevel>None</AnalysisLevel>
    <!-- Compiler Warnings Suppression -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Fobiden to add global scoped NoWarn  violator to this rule will be prosecuted -->
  </PropertyGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Core Framework">
    <PackageReference Include="Microsoft.Extensions.Logging" />
  </ItemGroup>
  <ItemGroup Label="PLC Communication">
    <PackageReference Include="Sharp7" />
  </ItemGroup>
  <ItemGroup Label="Reactive Extensions">
    <PackageReference Include="System.Interactive" />
    <PackageReference Include="System.Reactive" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- SOLUTION FOLDERS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Solution Folders">
    <Folder Include="BatchRead\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="IndQuestResults" />
  </ItemGroup>
</Project>
