@using IndTrace.Application.BarCodes.Commands.Reject
@using IndTrace.Application.BarCodes.Queries.GetBarCodeDetailMonitor
@using IndTrace.Application.Models.RequestHandler
@using IndTrace.Domain.Interfaces

@using Microsoft.Extensions.Logging
@inject IMonitorRequestDispatcher MonitorRequestDispatcher
@inject ILogger<BarCodeReject> Logger


<AuthorizeView>
    <Authorized>
        @if (!string.IsNullOrWhiteSpace(BarCode))
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="4" Class="mt-4">
                        <MudCard>
                            <MudCardHeader>
                                <MudText Typo="Typo.h6">Selected BarCode @BarCode</MudText>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText>Submit to Reject</MudText>
                                <MudButton Color="Color.Primary" OnClick="RejectBarcode">Reject</MudButton>
                            </MudCardContent>
                        </MudCard>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </Authorized>
    <NotAuthorized>
        <MudText Typo="Typo.h6"><b>Logging to edit:</b> </MudText>
    </NotAuthorized>
</AuthorizeView>

@if (string.IsNullOrEmpty(BarCodeRejected?.Label))
    {
    <MudAlert Severity="Severity.Error">No BarCode Found</MudAlert>
}
else
{
    <MudAlert Severity="Severity.Success">BarCode Rejected</MudAlert>

    <MudCard Style="max-width: 400px; margin: auto;">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">Machine Information</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Machine ID:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRejected.MachineId</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Barcode ID:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRejected.BarCodeId</MudText>
                </MudItem>

              <MudItem xs="6">
                    <MudText Typo="Typo.body1">Flow Status:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRejected.FlowStatus</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Part Status:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRejected.PartStatus</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider />
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Label:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRejected.Label</MudText>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>


}



@code {

    [Parameter]
    public string BarCode { get; set; } = string.Empty;

    public string Result { get; set; } = string.Empty;

    private BarCodeRejectedView? BarCodeRejected;

    private async Task RejectBarcode()
    {
        try
        {
            var request = new RejectBarCodeCommand
                {
                    Label = BarCode,

                };
            var result = await MonitorRequestDispatcher.QueryAsync(request);

            Result = result.IsSuccess ? "Rejected" : "Failed";

            BarCodeRejected = result.Value;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Result= "Failed";
            Logger.LogError(ex, "Error while restoring barcode");
        }
    }

}
