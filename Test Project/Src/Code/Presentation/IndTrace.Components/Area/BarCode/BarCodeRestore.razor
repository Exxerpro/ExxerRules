@using IndTrace.Application.BarCodes.Commands.Restore
@using IndTrace.Application.BarCodes.Queries.GetBarCodeDetailMonitor
@using IndTrace.Application.Models.RequestHandler
@using IndTrace.Domain.Interfaces

@using Microsoft.Extensions.Logging
@inject IMonitorRequestDispatcher MonitorRequestDispatcher
@inject ILogger<BarCodeRestore> Logger


<AuthorizeView>
    <Authorized>
        @if (!string.IsNullOrWhiteSpace(BarCode))
        {
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="4" Class="mt-4">
                        <MudCard>
                            <MudCardHeader>
                                <MudText Typo="Typo.h6">Selected BarCode @BarCode</MudText>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText>Submit to Restore</MudText>
                                <MudButton Color="Color.Primary" OnClick="RestoreBarcode">Submit</MudButton>
                            </MudCardContent>
                        </MudCard>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </Authorized>
    <NotAuthorized>

    </NotAuthorized>
</AuthorizeView>

@if (!string.IsNullOrEmpty(BarCodeRestored?.Label))


{
    <MudAlert Severity="Severity.Success">BarCode Restored</MudAlert>

    <MudCard Style="max-width: 400px; margin: auto;">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6">Machine Information</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Machine ID:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRestored.MachineId</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Barcode ID:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRestored.BarCodeId</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Flow Status:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRestored.FlowStatus</MudText>
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Part Status:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRestored.PartStatus</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider />
                </MudItem>

                <MudItem xs="6">
                    <MudText Typo="Typo.body1">Label:</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.body1">@BarCodeRestored.Label</MudText>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>


}



@code {

    [Parameter]
    public string BarCode { get; set; } = string.Empty;

    public string Result { get; set; } = string.Empty;

    private BarCodeRestoredView? BarCodeRestored;

    private async Task RestoreBarcode()
    {
        try
        {
            var request = new RestoreBarCodeCommand
                {
                    Label = BarCode,

                };
            var result = await MonitorRequestDispatcher.ProcessAsync(request);

            Result = result.IsSuccess ? "Restored" : "Failed";

            BarCodeRestored = result.Value;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Result= "Failed";
            Logger.LogError(ex, "Error while restoring barcode");
        }
    }

}
