@using IndTrace.Application.UI.Models
@using MudBlazor

<MudTable Items="@PlcConnections.Values"
          Dense="true"
          Hover="true"
          Breakpoint="Breakpoint.Sm"
          Loading="@_loading"
          LoadingProgressColor="Color.Info">

    <HeaderContent>
        <MudTh>PLC Name</MudTh>
        <MudTh>IP Address</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="PLC">
            <MudText Color="@GetColor(context)">
                @context.Name
            </MudText>

        </MudTd>
        <MudTd DataLabel="IP">
            <MudText Color="@GetColor(context)">
                @context.IpAddress
            </MudText>
           <MudIcon Icon="@GetICon(context)" Color="@GetColor(context)"/>
        </MudTd>

    </RowTemplate>
</MudTable>



<MudPaper Class=" pa-4 align-start d-flex" Outlined="true">
    <MudPaper Class="pa-3" Elevation="6">
        <MudButton Disabled="@_loading" OnClick="Refresh" Variant="Variant.Filled" Color="Color.Primary">
            @if (_loading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                <MudText Class="ms-2">Refreshing</MudText>
            }
            else
            {
                <MudText>Refresh status</MudText>
            }
        </MudButton>
    </MudPaper>
    <MudSpacer />
    <MudPaper Class="pa-3" Elevation="6">
        <MudIconButton Icon="@Icons.Material.Filled.Troubleshoot"
                       OnClick="Refresh" aria-label="Refresh"> Refresh
        </MudIconButton>
    </MudPaper>
</MudPaper>



<MudSpacer />




@code {


    private bool _loading = false;

    [Parameter]
    public IReadOnlyDictionary<int ,ControllerMonitor> PlcConnections { get; set; } = new Dictionary<int, ControllerMonitor>();

    private string GetICon(ControllerMonitor controllerMonitor)
    {
        return controllerMonitor.IsConnected ?
            @Icons.Material.Filled.Link :
            @Icons.Material.Filled.LinkOff;
    }

    private Color GetColor(ControllerMonitor controllerMonitor)
    {
        return controllerMonitor.IsConnected ? Color.Success : Color.Error;
    }


    private System.Threading.Timer? _timer;

    private async Task Refresh()
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);
        foreach(var plc in PlcConnections.Values)
        {
            plc.RefreshConnection();
        }
        // Unsubscribe and resubscribe events
        foreach (var plc in PlcConnections.Values)
        {
            if (plc is null)
            {
                continue;
            }

            plc.ConnectionLost -= OnConnectionLost;
            plc.ConnectionRecovered -= OnConnectionRecovered;

            plc.ConnectionLost += OnConnectionLost;
            plc.ConnectionRecovered += OnConnectionRecovered;

            plc.RefreshConnection();
        }


        // Set up a timer to fire an event after 3 seconds
        _timer = new Timer(async (state) =>
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }, null, 3000, Timeout.Infinite);
    }

    // subscribe to events from the plc on parameters set
    // Subscribe to events from the plc on parameters set
    protected override void OnParametersSet()
    {
        foreach (var plc in PlcConnections.Values)
        {
            plc.ConnectionLost -= OnConnectionLost;
            plc.ConnectionRecovered -= OnConnectionRecovered;

            plc.ConnectionLost += OnConnectionLost;
            plc.ConnectionRecovered += OnConnectionRecovered;
        }
    }

    private void OnConnectionLost(object? sender, EventArgs args)
    {
         InvokeAsync(StateHasChanged);
    }

    private void OnConnectionRecovered(object? sender, EventArgs args)
    {
         InvokeAsync(StateHasChanged);
    }

}
