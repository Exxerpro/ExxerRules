@using Microsoft.AspNetCore.SignalR.Client
@using System.Globalization
@using IndTrace.Application.Models.Helpers
@using IndTrace.Application.UI.Models
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using IndTrace.Application.ConfigStations.Queries.GetConfigStationList;
@using IndTrace.Domain.Entities
@using Microsoft.Extensions.Logging

@inject IJSRuntime JS
@inject ILogger<RequestsTable> Logger


@if (GatewayRequests is null || !GatewayRequests.Any() )
{


<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.h6" Color="Color.Secondary">
        No station data available.
    </MudText>
</MudPaper>
}
else
{

    <MudTable Items="GatewayRequests" Dense="true" Hover="true" Striped="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6" Color="Color.Tertiary">Events</MudText>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>MachineRecipePerformanceDataKpiOeeUserRegisterId</MudTh>
            <MudTh>Task</MudTh>
            <MudTh>Label</MudTh>
            <MudTh>PartNumber</MudTh>
            <MudTh>PartStatus</MudTh>
            <MudTh>CycleStatus</MudTh>
            <MudTh>TimeStamp</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Machine">
                @(MachineNames.TryGetValue(context.MachineId, out var machineName) ? machineName : $"Unknown ({context.MachineId})")
            </MudTd>
            <MudTd DataLabel="Task">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small">
                    @(context.RequestTask ?? "Unknown")
                </MudButton>
            </MudTd>
            <MudTd DataLabel="Label">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           OnClick="() => CopyToClipboard(context.BarCode)">
                    @(context.BarCode ?? "N/A")
                </MudButton>
            </MudTd>
            <MudTd DataLabel="PartNumber">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                    @(context.PartNumber ?? "N/A")
                </MudButton>
            </MudTd>
            <MudTd DataLabel="PartStatus">@(context.PartStatus?.Name ?? "None")</MudTd>
            <MudTd DataLabel="CycleStatus">@(context.CycleStatus?.Name ?? "None")</MudTd>

            <MudTd DataLabel="TimeStamp">@(context.TimeStamp)</MudTd>
        </RowTemplate>
    </MudTable>

}

@code {

    [Parameter]
    public IEnumerable<TaskGatewayRequest> GatewayRequests { get; set; } = [];

    [Parameter]
    public Dictionary<int, string> MachineNames { get; set; } = new();

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("copyToClipboard", text);
    }
}
