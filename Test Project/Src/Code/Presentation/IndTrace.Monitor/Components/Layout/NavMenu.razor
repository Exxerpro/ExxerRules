@implements IDisposable
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Antiforgery
@using MudBlazor

<MudPaper Height="800px" Style="overflow:hidden; position:relative;">
    <MudDrawerContainer Class="mud-height-full">
        <MudDrawer @bind-Open="@_open" Elevation="0" Variant="DrawerVariant.Persistent" Class="custom-drawer">
            <MudDrawerHeader>
                <MudText Typo="Typo.h6">IndTrace</MudText>
            </MudDrawerHeader>

            <MudNavMenu Dense="true">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home" Class="mud-nav-link">Home</MudNavLink>
                <MudNavLink Href="/machines" Icon="@Icons.Material.Filled.Build" Class="mud-nav-link">Machines</MudNavLink>
                <MudNavLink Href="/monitor" Icon="@Icons.Material.Filled.DesktopWindows" Class="mud-nav-link">Monitor</MudNavLink>
                <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Assessment" Class="mud-nav-link">Reports</MudNavLink>
                <MudNavLink Href="/barcode" Icon="@Icons.Material.Filled.QrCodeScanner" Class="mud-nav-link">BarCode</MudNavLink>
                <MudNavLink Href="/configuration" Icon="@Icons.Material.Filled.Settings" Class="mud-nav-link">Configuration</MudNavLink>
                <MudNavLink Href="/operations" Icon="@Icons.Material.Filled.Dashboard" Class="mud-nav-link">Operations</MudNavLink>
                @*    <MudNavLink Href="/metrics" Icon="@Icons.Material.Filled.Memory" Class="mud-nav-link">Metrics</MudNavLink>*@
                @*  <MudNavLink Href="/wifi" Icon="@Icons.Material.Filled.NetworkWifi" Class="mud-nav-link">BarCodes</MudNavLink> *@
                <MudNavLink Href="/products" Icon="@Icons.Material.Filled.SwapHoriz" Class="mud-nav-link">Products</MudNavLink>


              @*   <MudNavLink Href="/oee" Icon="@Icons.Material.Filled.DataThresholding" Class="mud-nav-link">oee</MudNavLink>
                <MudNavLink Href="/analyzer" Icon="@Icons.Material.Filled.DatasetLinked" Class="mud-nav-link">analyzer</MudNavLink>
                <MudNavLink Href="/notifications" Icon="@Icons.Material.Filled.DeveloperBoard" Class="mud-nav-link">notifications</MudNavLink>
                <MudNavLink Href="/registers" Icon="@Icons.Material.Filled.EditCalendar" Class="mud-nav-link">registers</MudNavLink>
                <MudNavLink Href="/shifts" Icon="@Icons.Material.Filled.EventNote" Class="mud-nav-link">shifts</MudNavLink> *@


                <MudNavLink Href="auth" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Lock">Auth Required</MudNavLink>
                <AuthorizeView>
                    <Authorized>
                        <MudNavLink Href="Account/Manage" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">@context.User.Identity?.Name</MudNavLink>
                        <MudNavLink Href="Account/logout" Icon="@Icons.Material.Filled.Logout" Class="mud-nav-link">LogOut</MudNavLink>
@*
                        <form action="Account/Logout" method="post">
                            @attribute [RequireAntiforgeryToken(false)]
                            <AntiforgeryToken/>
                            <input type="hidden" name="ReturnUrl" value="@currentUrl"/>
                            <button type="submit" class="mud-nav-link mud-ripple">
                                <MudIcon Icon="@Icons.Material.Filled.Logout" Color="Color.Info" Class="mr-3"></MudIcon> Logout
                            </button>
                        </form> *@
                    </Authorized>
                    <NotAuthorized>
                        <MudNavLink Href="Account/Register" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">Register</MudNavLink>
                        <MudNavLink Href="Account/Login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Password">Login</MudNavLink>
                    </NotAuthorized>
                </AuthorizeView>

            </MudNavMenu>
        </MudDrawer>
    </MudDrawerContainer>
</MudPaper>

@code {
    private bool _open = true;

    private string? _currentUrl;

    protected override void OnInitialized()

    {

        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);

        NavigationManager.LocationChanged += OnLocationChanged;

    }



    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)

    {

        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);

        StateHasChanged();

    }



    public void Dispose()

    {

        NavigationManager.LocationChanged -= OnLocationChanged;

    }
}
