@page "/metrics"

@using IndTrace.Application.Registers.Services
@using MudBlazor
@using IndTrace.Components.Area.Metrics
@using IndTrace.UI.Models.Metrics
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.JSInterop
@inject IRegisterInformationService  RegisterService


@inject ILogger<Metrics> Logger
@inject IJSRuntime JsRuntime
@inject ProtectedLocalStorage LocalStorage

@implements IAsyncDisposable

<h3>Metrics</h3>
<div id="particles-js"></div>

<MudDivider DividerType="DividerType.Middle"></MudDivider>

<MudCard xs="12">
    <MetricsSelect Registers="VariablesList"
                   SelectedValuesSaved="SelectedValuesChanged"
                   RefreshValues="RefreshValues" />

</MudCard>


<MudCard xs="12">

    @if(DataSet is null)
    {
        <MudText Color="Color.Error">Loading ..0</MudText>
    }
    else
    {
        <MetricsView
            Variables="@DataSet"
            OnSeriesDeleted="OnSeriesDeleted">
        </MetricsView>
    }

</MudCard>

<MudDivider DividerType="DividerType.Middle"></MudDivider>


<MudDivider DividerType="DividerType.Middle"></MudDivider>


<style>

    #particles-js {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        z-index: -1;
        background-image: url("");
        background-repeat: no-repeat;
        background-size: cover;
        background-position: 50% 50%;
    }
</style>
