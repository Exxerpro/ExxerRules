@page "/monitor"

@using IndTrace.Application.Configuration.Services
@using IndTrace.Application.Models.Helpers
@using IndTrace.Application.UI.Services
@using IndTrace.Components.Area.Monitor
@using IndTrace.Dependencies
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.JSInterop
@using MudBlazor


@inject IJSRuntime JsRuntime
@inject ILogger<Monitor> Logger
@inject IndTraceEventsService EventsService
@inject IndTraceConfigurationService IndTraceConfigurationService

@implements IAsyncDisposable


<div id="particles-js"></div>
<MudText>@SelectedCustomer</MudText>


<MudButton Disabled="@_processing" OnClick="SelectCustomer" Variant="Variant.Filled" Color="Color.Primary">
    @if (_processing)
    {
        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
        <MudText Class="ms-2">Processing</MudText>
    }
    else
    {
        <MudText>Select Customer</MudText>
    }
</MudButton>



@code {
    private bool _processing = false;

    async Task SelectCustomer()
    {
        _processing = true;

        if (applicationConfiguration?.ActiveCustomer is not null)
        {
            foreach (var customer in applicationConfiguration.ActiveCustomer)
            {

                Logger.LogInformation("Customer Name on this Application are {customer}", customer.Name);

            }
        }

        await Task.Delay(2000);
        _processing = false;
    }
}


@if (!IsInitialized)
{
    <MudProgressLinear Color="Color.Tertiary" Size="Size.Large" Rounded="true" Indeterminate="true" />
}




@if (applicationConfiguration is null)
{
    <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Error">
        <strong>Configuration Error:</strong> Unable to load the application configuration.
    </MudAlert>
}






@if (CanRender)
{
<MudSelect T="string" Label="Select Customer"
               @bind-Value="SelectedCustomer"
               Adornment="Adornment.Start"
               AdornmentIcon="@Icons.Material.Filled.Business"
               Clearable="true"
               Dense="true">
        @if (applicationConfiguration?.ActiveCustomer is not null)
        {
            @foreach (var customer in applicationConfiguration.ActiveCustomer)
            {
                <MudSelectItem Value="@customer.Name">
                    <MudImage Class="mr-2" Width="24" Height="24" Src="@GetCustomerLogoUrl(customer.Name)" /> @customer.Name
                </MudSelectItem>
            }
        }
    </MudSelect>


    @if (HasControllerMonitors)
    {
        <PlcMonitorTable Plcs=EventsService.ControllerMonitors?.Values MachineNames=applicationConfiguration?.MachineNames />
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Secondary" Align="Align.Center">
                No data found from the Events Service.
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                Please ensure that your controllers are connected and try again.
            </MudText>
        </MudPaper>
    }

    @if (HasRequestEvents)
    {
        <RequestsTable GatewayRequests=EventsService.RequestEvents?.Values MachineNames=applicationConfiguration?.MachineNames  />
    }
    else
    {

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Secondary" Align="Align.Center">
                No Request Events available.
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                Please verify the gateway status or try refreshing the data.
            </MudText>
        </MudPaper>
    }
}

@if (HasStationMonitors)
    {
       <StationsTable Stations=EventsService.StationMonitors?.Values MachineNames=applicationConfiguration?.MachineNames />
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Secondary" Align="Align.Center">
                No Station Monitor data available.
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                Please check your station connections or try refreshing the page.
            </MudText>
        </MudPaper>
    }


    @if (HasMessages)
    {
        <MudList T="FixedSizedStack<string>">
            @if (EventsService.Messages != null)
            {
                foreach (var message in EventsService.Messages)
                {
                    <MudListItem Dense="true">@message</MudListItem>
                }
            }
        </MudList>
    }
    else
    {
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Color="Color.Secondary" Align="Align.Center">
                No messages to display.
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                Message log is currently empty.
            </MudText>
        </MudPaper>
    }


<style>

    #particles-js {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        z-index: -1;
        background-image: url("");
        background-repeat: no-repeat;
        background-size: cover;
        background-position: 50% 50%;
    }

</style>
