{
  "ConnectionStrings": {
    "IndTraceDbContext": "Server=DESKTOP-FB2ES22\\SQL2022;Database=IndTraceDataQA45;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbIdentity": "Server=DESKTOP-FB2ES22\\SQL2022;Database=IndTraceIdentity;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "DefaultConnection": "DataSource=Data\\app.db;Cache=Shared"
  },
  "HubMonitorOptions": {
    "Url": "https://localhost:5201/eventmonitor",
    "AcceptAnyServerCertificate": true,
    "RetryTime": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Seq", "Serilog.Sinks.Async", "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "LevelSwitches": { "$controlSwitch": "Information" },
    "Override": {
      "Microsoft": "Information",
      "Microsoft.AspNetCore.SignalR": "Information"
      "Microsoft.AspNetCore.SignalR.Client.HubConnection": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "controlLevelSwitch": "$controlSwitch"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level}] ({Caller}){NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "D:\\Logs\\IndTrace\\Communications\\Logs\\Log-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": "100000000",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithExceptionDetails" ],
    "Properties": {
      "Application": "IndTrace.Communications"
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Contains(@Message, 'Failed to find handler for') or Contains(@Message, 'Failed to bind arguments received in invocation') or Contains(@Message, 'System.IO.InvalidDataException: Invocation provides 2 argument(s) but target expects 0')"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
