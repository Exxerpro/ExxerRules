<Project Sdk="Microsoft.NET.Sdk">
  <!-- ============================================================================ -->
  <!-- CORE PROPERTIES -->
  <!-- ============================================================================ -->
  <PropertyGroup>
    <!-- Application Type -->
    <OutputType>Exe</OutputType>
    <!-- Target Framework -->
    <TargetFramework>net10.0</TargetFramework>
    <!-- Language Features -->
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsTestingPlatformApplication>false</IsTestingPlatformApplication>
    <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>
    <IsPackable>false</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Assembly Information -->
    <RootNamespace>Application.UnitTests</RootNamespace>
    <AssemblyName>Application.UnitTests</AssemblyName>
    <!-- Test Project Configuration -->
    <IsTestProject>true</IsTestProject>
    <!-- Warnings as Errors Configuration -->
    <!-- CLEAN CODE STARTS WITH CLEAN TESTS! All CS86xx violations MUST be fixed -->
    <!-- WarningsNotAsErrors REMOVED - CS86xx warnings are LIFE THREATENING -->
    <!-- Versioning -->
    <AssemblyVersion>2020.5.30.9</AssemblyVersion>
    <FileVersion>2020.5.30.9</FileVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Fobiden to add global scoped NoWarn  violator to this rule will be prosecuted -->
  </PropertyGroup>
  <!-- ============================================================================ -->
  <!-- TESTING PLATFORM PROPERTIES -->
  <!-- ============================================================================ -->
  <PropertyGroup>
    <!-- Microsoft Testing Platform Configuration -->
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <TestingPlatformServer>true</TestingPlatformServer>
  </PropertyGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - TESTING FRAMEWORKS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="xUnit v3">
    <PackageReference Include="Microsoft.AspNetCore.Http" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.v3.core" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - VISUAL STUDIO RUNNER -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Visual Studio Runner">
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Microsoft.Testing.Extensions.VSTestBridge" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3.runner.inproc.console" />
    <PackageReference Include="xunit.v3.runner.msbuild">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- MICROSOFT TESTING PLATFORM -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Microsoft Testing Platform">
    <PackageReference Include="Microsoft.Testing.Platform" />
    <PackageReference Include="Microsoft.Testing.Platform.MSBuild" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - TESTING UTILITIES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Testing Utilities">
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="Shouldly" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - LOGGING -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Logging">
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Meziantou.Extensions.Logging.Xunit.v3" />
    <PackageReference Include="Serilog.Enrichers.Demystifier" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - ENTITY FRAMEWORK -->
  <!-- ============================================================================ -->
  <!-- [ARCH] Entity Framework references removed from Application tests - moved to Aggregation tests
  <ItemGroup Label="Entity Framework Testing">
	<PackageReference Include="MockQueryable.EntityFrameworkCore" />
	<PackageReference Include="Microsoft.EntityFrameworkCore" />
	<PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" />
	<PackageReference Include="EntityFrameworkCore.Testing.NSubstitute" />
  </ItemGroup>
  -->

  <!-- ============================================================================ -->
  <!-- RESULT ANALYZERS -->
  <!-- ============================================================================ -->
  <!-- Temporarily disabled to focus on test fixes
  <ItemGroup Label="Result Analyzers">
  <PackageReference Include="IndQuestResults.Analyzers">
	  <PrivateAssets>all</PrivateAssets>
	  <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
  </PackageReference>
  </ItemGroup>
  -->

  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - CODE ANALYSIS -->
  <!-- ============================================================================ -->
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - ANALYZERS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="NSubstitute Analyzers">
    <PackageReference Include="NSubstitute.Analyzers.CSharp">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - TIME PROVIDER -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Time Testing">
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - REACTIVE EXTENSIONS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Reactive Extensions">
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="System.Reactive.Linq" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- CONTENT FILES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Configuration Files">
    <Content Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- USING DIRECTIVES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Global Usings">
    <Using Include="Xunit" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PROJECT REFERENCES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Core References">
    <ProjectReference Include="..\..\..\Code\Core\Application\IndTrace.Application.csproj" />
    <ProjectReference Include="..\..\..\Code\Core\Domain\IndTrace.Domain.csproj" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- SOLUTION FOLDERS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Solution Folders">
    <Folder Include="Features\Attributes\" />
    <Folder Include="Features\Constants\" />
    <Folder Include="Features\Mediator\" />
    <Folder Include="Features\Models\" />
    <Folder Include="Features\Notifications\" />
    <Folder Include="Features\Performance\" />
    <Folder Include="Services\" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="**\XunitAutoGeneratedEntryPoint.cs" />
    <Compile Remove="AutoGenerated\**\XunitAutoGeneratedEntryPoint.cs" />
    <Compile Remove="obj\**\XunitAutoGeneratedEntryPoint.cs" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PROJECT CAPABILITIES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Testing Platform Capabilities">
    <ProjectCapability Include="DiagnoseCapabilities" />
    <ProjectCapability Include="TestingPlatformServer" />
    <ProjectCapability Include="TestContainer" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="IndQuestResults" />
    <PackageReference Include="IndFusion.Fixer" />
    <PackageReference Include="IndFusion.Analyzer">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
