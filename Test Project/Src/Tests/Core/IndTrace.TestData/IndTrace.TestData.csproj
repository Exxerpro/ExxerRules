<Project Sdk="Microsoft.NET.Sdk">
  <!-- ============================================================================ -->
  <!-- CORE PROPERTIES -->
  <!-- ============================================================================ -->
  <PropertyGroup>
    <!-- Application Type -->
    <OutputType>Exe</OutputType>
    <!-- Target Framework -->
    <TargetFramework>net10.0</TargetFramework>
    <!-- Language Features -->
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Warning Suppressions -->
    <!-- Fobiden to add global scoped NoWarn  violator to this rule will be prosecuted -->
    <!-- Assembly Information -->
    <RootNamespace>IndTrace.TestData</RootNamespace>
    <AssemblyName>IndTrace.TestData</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsTestingPlatformApplication>false</IsTestingPlatformApplication>
    <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Versioning -->
    <AssemblyVersion>2020.5.30.51</AssemblyVersion>
    <FileVersion>2020.5.30.51</FileVersion>
    <!-- Testing Startup -->
    <XunitStartupAssembly>IndTrace.TestData</XunitStartupAssembly>
    <!-- Description -->
    <Description>Industrial traceability test data with embedded resources for consistent test scenarios across all projects</Description>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>
  <!-- ============================================================================ -->
  <!-- TESTING PLATFORM PROPERTIES -->
  <!-- ============================================================================ -->
  <PropertyGroup>
    <!-- Microsoft Testing Platform Configuration -->
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <TestingPlatformServer>true</TestingPlatformServer>
  </PropertyGroup>
  <!-- ============================================================================ -->
  <!-- EMBEDDED RESOURCES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Embedded Resources">
    <!-- Embed all JSON files as resources for bulletproof cross-platform access -->
    <EmbeddedResource Include="Data\*.json" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - CORE TESTING -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Core Testing">
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Chill" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - TESTING UTILITIES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Testing Utilities">
    <!-- NSubstitute removed - TestData should only provide data, no mocking -->
    <PackageReference Include="Shouldly" />
    <PackageReference Include="Serilog.Enrichers.Demystifier" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - ENTITY FRAMEWORK -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Entity Framework">
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - LOGGING -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Logging">
    <PackageReference Include="Meziantou.Extensions.Logging.Xunit.v3" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - TIME TESTING -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Time Testing">
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PACKAGE REFERENCES - CODE ANALYSIS -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Code Analysis">
    <PackageReference Include="coverlet.collector">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!-- NSubstitute.Analyzers.CSharp removed - TestData should not have mock analyzers -->
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- MICROSOFT TESTING PLATFORM -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Microsoft Testing Platform">
    <PackageReference Include="Microsoft.Testing.Platform" />
    <PackageReference Include="Microsoft.Testing.Platform.MSBuild" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- XUNIT V3 FRAMEWORK -->
  <!-- ============================================================================ -->
  <ItemGroup Label="xUnit v3">
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.v3.core" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PROJECT CAPABILITIES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Testing Platform Capabilities">
    <ProjectCapability Include="DiagnoseCapabilities" />
    <ProjectCapability Include="TestingPlatformServer" />
    <ProjectCapability Include="TestContainer" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- FRIEND ASSEMBLIES (Internals Visible To) -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Friend Assemblies">
    <InternalsVisibleTo Include="IndTrace.Agregation.Dependices" />
  </ItemGroup>
  <!-- ============================================================================ -->
  <!-- PROJECT REFERENCES -->
  <!-- ============================================================================ -->
  <ItemGroup Label="Core References">
    <ProjectReference Include="..\..\..\Code\Core\Domain\IndTrace.Domain.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="DataFile\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="IndQuestResults" />
  </ItemGroup>
</Project>
