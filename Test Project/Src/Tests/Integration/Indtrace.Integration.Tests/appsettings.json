{
  "ConnectionStrings": {
    "IndTraceDbContext45": "Server=DESKTOP-FB2ES22\\SQL2022;Database=IndTraceDataQA45;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbContext46": "Server=DESKTOP-FB2ES22\\SQL2022;Database=IndTraceDataQA46;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbContext62": "Server=DESKTOP-FB2ES22\\SQL2022;Database=IndTraceDataQA62;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;",
    "IndTraceDbIdentity": "Server=localhost;Database=IndTraceIdentity;Trusted_Connection=True;Encrypt=False;TrustServerCertificate=True;"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5100"
      },
      "Https": {
        "Url": "https://*:5101"
      }
    }
  },
  "DataManSettings": {
    "IpAddress": "192.168.0.30",
    "UserName": "admin",
    "Password": "admin"
  },

  "HubMonitorOptions": {
    "Url": "https://localhost:5201/EventMonitor",
    "HubName": "EventMonitorHub",
    "AcceptAnyServerCertificate": true,
    "RetryTime": 5000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Seq", "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "LevelSwitches": { "$controlSwitch": "Information" },
    "Override": {
      "Microsoft": "Information",
      "Microsoft.AspNetCore.SignalR": "Debug",
      "Microsoft.AspNetCore.SignalR.Client.HubConnection": "Debug"
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "controlLevelSwitch": "$controlSwitch"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level}] ({Caller}) {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "D:\\Logs\\IndTrace\\Monitor\\Logs\\log.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": "100000000",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithExceptionDetails" ],
    "Properties": {
      "Application": "IndTrace.Monitor"
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Contains(@Message, 'Failed to find handler for') or Contains(@Message, 'Failed to bind arguments received in invocation') or Contains(@Message, 'System.IO.InvalidDataException: Invocation provides 2 argument(s) but target expects 0')"
        }
      }
    ]
  },
  "Application": {
    "Name": "IndTrace",
    "Service": "Monitor",
    "Communications": "false",
    "Dashboard": "false",
    "Monitor": "true",
    "Reports": "false",
    "FlowConnect": "false",
    "LogsPath": "D:\\Logs\\Communications"
  },

  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET_KEY_HERE"
  },
  "AllowedHosts": "*"
}
