{
  "stryker-config": {
    "project": "ExxerAI.sln",
    "test-projects": [
      "src/tests/ExxerAI.Application.Tests/ExxerAI.Application.Tests.csproj",
      "src/tests/ExxerAI.Domain.Tests/ExxerAI.Domain.Tests.csproj",
      "src/tests/ExxerAI.Infrastructure.Tests/ExxerAI.Infrastructure.Tests.csproj",
      "src/tests/ExxerAI.Api.Tests/ExxerAI.Api.Tests.csproj",
      "src/tests/ExxerAI.CLI.Tests/ExxerAI.CLI.Tests.csproj",
      "src/tests/ExxerAI.Orchestration.Tests/ExxerAI.Orchestration.Tests.csproj",
      "src/tests/ExxerAi.MCPServer.Tests/ExxerAi.MCPServer.Tests.csproj"
    ],
    "mutate": [
      "ExxerAI.Application/**/*.cs",
      "ExxerAI.Domain/**/*.cs",
      "ExxerAI.Infrastructure/**/*.cs",
      "ExxerAI.Api/**/*.cs",
      "ExxerAI.CLI/**/*.cs",
      "ExxerAI.Orchestration/**/*.cs",
      "ExxerAI.UI/**/*.cs",
      "ExxerAi.MCPServer/**/*.cs",
      "!**/*Tests.cs",
      "!**/*Test.cs",
      "!**/bin/**",
      "!**/obj/**",
      "!**/*.Designer.cs",
      "!**/*.g.cs",
      "!**/*.g.i.cs",
      "!**/AssemblyInfo.cs",
      "!**/GlobalUsings.cs",
      "!**/Program.cs"
    ],
    "ignore-methods": [
      "Console.Write*",
      "LogDebug",
      "LogInformation",
      "LogWarning",
      "LogError",
      "LogCritical",
      "LogTrace",
      "*Log*Debug*",
      "*Log*Information*",
      "*Log*Warning*",
      "*Log*Error*",
      "*Log*Critical*",
      "*Log*Trace*",
      "*Task.Delay*",
      "*ArgumentNullException*",
      "*ArgumentException*"
    ],
    "ignore-mutations": [
      "String"
    ],
    "mutation-level": "Standard",
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 60
    },
    "coverage-analysis": "perTestInIsolation",
    "reporters": ["html", "progress", "json"],
    "verbosity": "info",
    "concurrency": 8,
    "disable-bail": false,
    "break-on-initial-test-failure": false,
    "report-file-name": "mutation-report"
  }
}
