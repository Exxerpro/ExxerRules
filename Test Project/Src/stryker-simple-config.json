{
  "stryker-config": {
    "project": "src/ExxerAI.sln",
    "mutate": [
      "src/ExxerAI.Application/**/*.cs",
      "!**/*Tests.cs",
      "!**/*Test.cs",
      "!**/bin/**",
      "!**/obj/**"
    ],
    "ignore-methods": [
      "*Log*",
      "*ToString*",
      "*GetHashCode*",
      "*Equals*"
    ],
    "reporters": ["html", "progress", "json"],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 50
    },
    "verbosity": "info",
    "concurrency": 4,
    "report-file-name": "ExxerAI-Mutation-Report"
  }
}
