<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <AssemblyName>indfusion</AssemblyName>
    <PackageVersion>1.0.8</PackageVersion>
    <Authors>IndFusion</Authors>
    <Description>Console wrapper for IndFusion CLI tools</Description>
    <PackageTags>refactoring;code-analysis;roslyn;cli;console</PackageTags>
  </PropertyGroup>


  <ItemGroup>
    <ProjectReference Include="IndFusion.Tools.Cli.Core\IndFusion.Tools.Cli.Core.csproj" />
  </ItemGroup>

</Project>
