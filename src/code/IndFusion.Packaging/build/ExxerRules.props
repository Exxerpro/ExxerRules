<Project>

  <!-- ExxerRules Analyzer Package Configuration -->
  <PropertyGroup>
    <ExxerRulesAnalyzersEnabled Condition="'$(ExxerRulesAnalyzersEnabled)' == ''">true</ExxerRulesAnalyzersEnabled>
  </PropertyGroup>

  <!-- Analyzer assemblies -->
  <ItemGroup Condition="'$(ExxerRulesAnalyzersEnabled)' == 'true'">
    <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\ExxerRules.Analyzers.dll" />
    <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\ExxerRules.CodeFixes.dll" />
  </ItemGroup>

</Project>
