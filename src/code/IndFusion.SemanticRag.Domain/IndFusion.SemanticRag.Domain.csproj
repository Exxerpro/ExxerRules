<Project Sdk="Microsoft.NET.Sdk">
  <!-- ===================================================================== -->
  <!-- Project Properties & Configuration                                      -->
  <!-- ===================================================================== -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    
    <!-- Package Information -->
    <PackageId>IndFusion.SemanticRag.Domain</PackageId>
    <PackageVersion>1.0.0</PackageVersion>
    <Authors>IndFusion</Authors>
    <Description>Domain layer for IndFusion Semantic RAG Platform</Description>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RootNamespace>IndFusion.SemanticRag.Domain</RootNamespace>
  </PropertyGroup>

  <!-- Global Usings -->
  <ItemGroup>
    <Using Include="IndQuestResults" />
  </ItemGroup>

  <!-- Package References -->
  <ItemGroup>
    <PackageReference Include="IndQuestResults" />
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- InternalsVisibleTo Configuration                                       -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <InternalsVisibleTo Include="IndFusion.SemanticRag.Tests" />
    <InternalsVisibleTo Include="IndFusion.SemanticRag.Application" />
    <InternalsVisibleTo Include="IndFusion.SemanticRag.Infrastructure" />
  </ItemGroup>
</Project>