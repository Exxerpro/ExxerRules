<Project Sdk="Microsoft.NET.Sdk.Web">
  <!-- ===================================================================== -->
  <!-- Project Properties & Configuration                                      -->
  <!-- ===================================================================== -->
  <PropertyGroup>
    <!-- CENTRALLY MANAGED - DO NOT ADD ANOTHER TargetFramework HERE -->
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    
    <!-- Package Information -->
    <PackageId>IndFusion.SemanticRag.WebAPI</PackageId>
    <PackageVersion>1.0.0</PackageVersion>
    <Authors>IndFusion</Authors>
    <Description>Web API for IndFusion Semantic RAG Platform</Description>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RootNamespace>IndFusion.SemanticRag.WebAPI</RootNamespace>
  </PropertyGroup>

  <!-- ===================================================================== -->
  <!-- Package Dependencies                                                   -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <!-- ASP.NET Core Web SDK already includes most Microsoft.Extensions packages -->
    <!-- Only include packages that are not included transitively -->
    
    <!-- ASP.NET Core -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="Swashbuckle.AspNetCore" />
    
    <!-- MCP Integration -->
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
    
    <!-- Note: Microsoft.AspNetCore.Cors removed - included with ASP.NET Core -->
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- Project References                                                     -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <ProjectReference Include="..\..\Mcp\IndFusion.Mcp.Server\IndFusion.Mcp.Server.csproj" />
    <ProjectReference Include="..\IndFusion.SemanticRag.Application\IndFusion.SemanticRag.Application.csproj" />
    <ProjectReference Include="..\IndFusion.SemanticRag.Infrastructure\IndFusion.SemanticRag.Infrastructure.csproj" />
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- InternalsVisibleTo Configuration                                       -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <InternalsVisibleTo Include="IndFusion.SemanticRag.Tests" />
  </ItemGroup>
</Project>
