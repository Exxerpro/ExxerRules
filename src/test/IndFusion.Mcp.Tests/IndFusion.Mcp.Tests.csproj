<Project Sdk="Microsoft.NET.Sdk">
  <!-- ===================================================================== -->
  <!-- Project Properties & Configuration                                      -->
  <!-- ===================================================================== -->
  <PropertyGroup>
    <!-- CENTRALLY MANAGED - DO NOT ADD ANOTHER TargetFramework HERE -->
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <WarningsNotAsErrors>CS0219</WarningsNotAsErrors>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <EnableMSTestRunner>true</EnableMSTestRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <RootNamespace>IndFusion.Mcp.Tests</RootNamespace>
  </PropertyGroup>
  <Import Project="..\TestingPlatform.props" />
  <!-- ===================================================================== -->
  <!-- Package Dependencies                                                   -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <!-- Testing Framework & Tools -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Update="xunit.v3.runner.console">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Update="xunit.v3.runner.msbuild">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <!-- Test Coverage -->
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Shouldly" />
    <PackageReference Include="NSubstitute" />
  </ItemGroup>
  <!-- ===================================================================== -->
  <!-- Global Using Statements                                                -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>
  <!-- ===================================================================== -->
  <!-- Project References                                                     -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <ProjectReference Include="..\..\code\IndFusion.Mcp.Core\IndFusion.Mcp.Core.csproj" />
  </ItemGroup>
  <!-- ===================================================================== -->
  <!-- Build Configuration                                                    -->
  <!-- ===================================================================== -->
  <!-- Exclude generated test files from compilation -->
  <ItemGroup>
    <Compile Remove="TestOutput\**\*.cs" />
    <None Include="TestOutput\**\*.cs" />
  </ItemGroup>
</Project>
