<Project Sdk="Microsoft.NET.Sdk">
  <!-- ===================================================================== -->
  <!-- Project Properties & Configuration                                      -->
  <!-- ===================================================================== -->
  <PropertyGroup>
    <!-- CENTRALLY MANAGED - DO NOT ADD ANOTHER TargetFramework HERE -->
    <OutputType>Exe</OutputType>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
	<TreatWarningsAsErrors>true</TreatWarningsAsErrors>
	<NoWarn>$(NoWarn);CS1591;CA1707;CA1859</NoWarn>
    <EnableMSTestRunner>true</EnableMSTestRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <TestingPlatformServer>true</TestingPlatformServer>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <RootNamespace>IndFusion.Mcp.Tests</RootNamespace>
  </PropertyGroup>
  <Import Project="..\TestingPlatform.props" />
  <!-- ===================================================================== -->
  <!-- Package Dependencies                                                   -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <!-- Testing Framework & Tools -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.v3.core" />
    <PackageReference Include="xunit.abstractions" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <!-- Test Coverage -->
    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Shouldly" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="NSubstitute.Analyzers.CSharp" />
    <PackageReference Include="IndQuestResults" />
    <PackageReference Include="Meziantou.Extensions.Logging.Xunit.v3" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" />
  </ItemGroup>
  <!-- ===================================================================== -->
  <!-- Global Using Statements                                                -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <Using Include="Xunit" />
    <Using Include="NSubstitute" />
    <Using Include="Shouldly" />
    <Using Include="Microsoft.Extensions.Logging" />
    <Using Include="System" />
    <Using Include="System.Collections.Generic" />
    <Using Include="System.Linq" />
    <Using Include="System.Threading" />
    <Using Include="System.Threading.Tasks" />
    <Using Include="System.Text" />
    <Using Include="System.IO" />
  </ItemGroup>
  <!-- ===================================================================== -->
  <!-- Project References                                                     -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <ProjectReference Include="..\..\code\IndFusion.Mcp.Core\IndFusion.Mcp.Core.csproj" />
  </ItemGroup>
  <!-- ===================================================================== -->
  <!-- Build Configuration                                                    -->
  <!-- ===================================================================== -->
  <!-- Exclude generated test files and fixtures from compilation -->
  <ItemGroup>
    <Compile Remove="TestOutput\**\*.cs" />
    <None Include="TestOutput\**\*.cs" />
    <!-- Exclude ExampleCode.cs - it's a test fixture, not compiled code -->
    <Compile Remove="ExampleCode.cs" />
    <None Include="ExampleCode.cs" />
    <!-- Exclude other common test fixture patterns -->
    <Compile Remove="**\*Sample.cs" />
    <Compile Remove="**\*Fixture.cs" />
    <None Include="**\*Sample.cs" />
    <None Include="**\*Fixture.cs" />
  </ItemGroup>
  
  <!-- ===================================================================== -->
  <!-- Testing Platform Capabilities                                         -->
  <!-- ===================================================================== -->
  <ItemGroup Label="Testing Platform Capabilities">
    <ProjectCapability Include="DiagnoseCapabilities" />
    <ProjectCapability Include="TestingPlatformServer" />
    <ProjectCapability Include="TestContainer" />
  </ItemGroup>
  
  <!-- ===================================================================== -->
  <!-- Test Organization Folders                                             -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <Folder Include="Architecture\" />
    <Folder Include="PatternGraph\" />
  </ItemGroup>
</Project>
