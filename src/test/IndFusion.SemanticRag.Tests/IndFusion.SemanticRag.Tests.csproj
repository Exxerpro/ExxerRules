  <!-- ===================================================================== -->
  <ItemGroup>
    <!-- Test Framework -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="coverlet.collector" />
    
    <!-- Assertion Library -->
    <PackageReference Include="Shouldly" />
    
    <!-- Mocking Library -->
    <PackageReference Include="NSubstitute" />
    
    <!-- Result Pattern -->
    <PackageReference Include="CSharpFunctionalExtensions" />
    
    <!-- Microsoft Extensions -->
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- Project References                                                     -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <ProjectReference Include="..\..\code\IndFusion.SemanticRag.Domain\IndFusion.SemanticRag.Domain.csproj" />
    <ProjectReference Include="..\..\code\IndFusion.SemanticRag.Application\IndFusion.SemanticRag.Application.csproj" />
    <ProjectReference Include="..\..\code\IndFusion.SemanticRag.Infrastructure\IndFusion.SemanticRag.Infrastructure.csproj" />
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- InternalsVisibleTo Configuration                                       -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <InternalsVisibleTo Include="IndFusion.SemanticRag.Tests.Integration" />
  </ItemGroup>
</Project>
