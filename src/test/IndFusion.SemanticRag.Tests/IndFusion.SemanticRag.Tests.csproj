<Project Sdk="Microsoft.NET.Sdk">
  <!-- ===================================================================== -->
  <!-- Project Properties & Configuration                                      -->
  <!-- ===================================================================== -->
  <PropertyGroup>
    <!-- CENTRALLY MANAGED - DO NOT ADD ANOTHER TargetFramework HERE -->
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RootNamespace>IndFusion.SemanticRag.Tests</RootNamespace>
  </PropertyGroup>
  <!-- Shared testing platform + xUnit v3 configuration for robust discovery across runners -->
  <PropertyGroup>
	  <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
	  <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
	  <TestingPlatformServer>true</TestingPlatformServer>
	  <IsTestingPlatformApplication>false</IsTestingPlatformApplication>
	  <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>
  </PropertyGroup>

  <ItemGroup>
	  <!-- xUnit v3 runners -->
	  <PackageReference Include="xunit.v3.runner.msbuild">
		  <PrivateAssets>all</PrivateAssets>
		  <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
	  </PackageReference>
	  <PackageReference Include="xunit.v3.runner.console">
		  <PrivateAssets>all</PrivateAssets>
	  </PackageReference>
	  <PackageReference Include="xunit.v3.runner.inproc.console" />

	  <!-- Microsoft Testing Platform (stable 1.8.4) and extensions -->
	  <PackageReference Include="Microsoft.Testing.Platform" />
	  <PackageReference Include="Microsoft.Testing.Platform.MSBuild" />
	  <PackageReference Include="Microsoft.Testing.Extensions.VSTestBridge" />
	  <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" />
	  <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
  </ItemGroup>

	<!-- ===================================================================== -->
  <!-- Package Dependencies                                                   -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <!-- Test Framework -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" />
    
    <!-- Assertion Library -->
    <PackageReference Include="Shouldly" />
    
    <!-- Mocking Library -->
    <PackageReference Include="NSubstitute" />
    
    <!-- Result Pattern -->
    <PackageReference Include="CSharpFunctionalExtensions" />
    
    <!-- Microsoft Extensions -->
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- Project References                                                     -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <ProjectReference Include="..\..\code\IndFusion.SemanticRag.Domain\IndFusion.SemanticRag.Domain.csproj" />
    <ProjectReference Include="..\..\code\IndFusion.SemanticRag.Application\IndFusion.SemanticRag.Application.csproj" />
    <ProjectReference Include="..\..\code\IndFusion.SemanticRag.Infrastructure\IndFusion.SemanticRag.Infrastructure.csproj" />
  </ItemGroup>

  <!-- ===================================================================== -->
  <!-- InternalsVisibleTo Configuration                                       -->
  <!-- ===================================================================== -->
  <ItemGroup>
    <InternalsVisibleTo Include="IndFusion.SemanticRag.Tests.Integration" />
  </ItemGroup>
</Project>
